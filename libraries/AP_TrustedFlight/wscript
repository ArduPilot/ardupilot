#!/usr/bin/env python3


def configure(cfg):
    if not cfg.env.AP_TRUSTED_FLIGHT_ENABLED:
        return

    # SITL reads trusted flight artifacts from `cwd` at runtime
    if cfg.env.BOARD_CLASS != 'SITL':
        cfg.env.TRUSTED_FLIGHT_KEY_TYPE = 1   # aligns with EdDSA in AP_TrustedFlight.h
        cfg.env.TRUSTED_FLIGHT_KEY = cfg.options.trusted_flight_key
        cfg.env.TRUSTED_FLIGHT_ISSUER = cfg.options.trusted_flight_issuer.strip().encode()

    cfg.define('AP_TRUSTED_FLIGHT_ENABLED', 1)
    # defaults to 0 when TRUSTED_FLIGHT_ISSUER is unset
    cfg.define('AP_TRUSTED_FLIGHT_ISSUER_LENGTH', len(cfg.env.TRUSTED_FLIGHT_ISSUER or b''))

    cfg.load('tiny_json')


def build(bld):
    if not bld.env.AP_TRUSTED_FLIGHT_ENABLED:
        return
    bld.load('tiny_json')
    bld.env.AP_LIBRARIES_OBJECTS_KW['use'] += ['tiny-json']
    bld.tiny_json()
