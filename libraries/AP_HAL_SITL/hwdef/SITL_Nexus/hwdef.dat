# SITL analogue of the mRoNexus flight controller.
#
# Instead of the pure-maths SITL IMU, this board exercises the real
# InvensenseV3 and ADIS1647x drivers against their simulated devices, giving
# the same inertial sensor complement as the real mRoNexus:
#   - InvensenseV3 ICM40609   (SPI, simulated by SITL::ICM40609)
#   - ADIS1647x    ADIS16470  (SPI, simulated by SITL::ADIS16470)

include ../sitl/hwdef.dat

# disable the built-in maths IMU so the real sensor drivers are used
define AP_SIM_INS_ENABLED 0

# probe the real drivers against the simulated SPI devices.  The SPI device
# names resolve against the SITL SPI device table (AP_HAL_SITL/SPIDevice.cpp).
IMU Invensensev3 SPI:icm40609 ROTATION_NONE
IMU ADIS1647x SPI:adis16470 ROTATION_NONE 0
