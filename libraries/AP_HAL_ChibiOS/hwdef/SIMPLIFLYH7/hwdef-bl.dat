# hw definition file for processing by chibios_hwdef.py
# bootloader for SimpliFly H7

# MCU class and specific type
MCU STM32H7xx STM32H743xx

# board ID. See Tools/AP_Bootloader/board_types.txt
APJ_BOARD_ID AP_HW_SIMPLIFLYH7

# crystal frequency
OSCILLATOR_HZ 8000000

FLASH_SIZE_KB 2048

# bootloader starts at zero offset
FLASH_RESERVE_START_KB 0

# the location where the bootloader will put the firmware
# must match FLASH_RESERVE_START_KB in hwdef.dat
FLASH_BOOTLOADER_LOAD_KB 128

define HAL_STORAGE_SIZE 32768

# USB only in bootloader
SERIAL_ORDER OTG1

PA11 OTG_FS_DM OTG1
PA12 OTG_FS_DP OTG1

PA13 JTMS-SWDIO SWD
PA14 JTCK-SWCLK SWD

# LED
PD1 LED_BOOTLOADER OUTPUT LOW
define HAL_LED_ON 0

# Buzzer (inverted - active LOW)
PD3 BUZZER OUTPUT HIGH PUSHPULL

# Keep all SPI CS pins high during bootloader to prevent bus conflicts
PC4  GYRO1_CS CS
PB12 OSD1_CS  CS
PD0  FLASH1_CS CS
