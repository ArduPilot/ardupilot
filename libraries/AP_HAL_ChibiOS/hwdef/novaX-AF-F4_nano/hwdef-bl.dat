# hw definition file for processing by chibios_hwdef.py
# for the novaX AF-F4 nano bootloader

# MCU class and specific type
MCU STM32F4xx STM32F405xx

# board ID 6203 (must match the application)
APJ_BOARD_ID AP_HW_novaX-AF-F4_nano

# crystal frequency, setup to use external oscillator
OSCILLATOR_HZ 8000000

FLASH_SIZE_KB 1024

# bootloader starts at zero offset
FLASH_RESERVE_START_KB 0

# the location where the bootloader will put the firmware
FLASH_BOOTLOADER_LOAD_KB 48

# order of UARTs (and USB)
SERIAL_ORDER OTG1

PA11 OTG_FS_DM OTG1
PA12 OTG_FS_DP OTG1

PA13 JTMS-SWDIO SWD
PA14 JTCK-SWCLK SWD

# Chip select pins
PC14 SDCARD1_CS CS
PB12 OSD1_CS CS
PA4 GYRO1_CS CS

PA8 LED_BOOTLOADER OUTPUT LOW
define HAL_LED_ON 0

# enable software DFU entry (app Util::boot_to_dfu -> bootloader __entry_hook)
ENABLE_DFU_BOOT 1
