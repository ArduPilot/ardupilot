# hw definition file for processing by chibios_hwdef.py
# for the AutoFly hardware
MCU STM32H7xx STM32H743xx
AP_BATTMONITOR_ENABLED 0
# board ID. See Tools/AP_Bootloader/board_types.txt
APJ_BOARD_ID AP_HW_AutoFly

# crystal frequency, setup to use external oscillator
OSCILLATOR_HZ 25000000

STM32_ST_USE_TIMER 5

# reserve 256 bytes for comms between app and bootloader
RAM_RESERVE_START 256

FLASH_SIZE_KB 128
FLASH_RESERVE_START_KB 0

EXT_FLASH_SIZE_MB 8
EXT_FLASH_RESERVE_START_KB 1024
EXT_FLASH_RESERVE_END_KB 448





PC5 RSSI_ADC ADC1

# order of UARTs (and USB)
SERIAL_ORDER  OTG1 USART2 USART1 

PA11 OTG_FS_DM OTG1
PA12 OTG_FS_DP OTG1

# GPS1
PA9  USART1_TX USART1
PA10 USART1_RX USART1

# TELEM1
PD6 USART2_RX USART2
PD5 USART2_TX USART2



# SWD
PA13 JTMS-SWDIO SWD
PA14 JTCK-SWCLK SWD

I2C_ORDER I2C1

# I2C1 - baro
PB8 I2C1_SCL I2C1
PB7 I2C1_SDA I2C1

PD11 QUADSPI_BK1_IO0 QUADSPI1 SPEED_HIGH
PD12 QUADSPI_BK1_IO1 QUADSPI1 SPEED_HIGH
PE2 QUADSPI_BK1_IO2 QUADSPI1 SPEED_HIGH
PD13 QUADSPI_BK1_IO3 QUADSPI1 SPEED_HIGH
PB6 QUADSPI_BK1_NCS QUADSPI1 SPEED_HIGH
PB2 QUADSPI_CLK QUADSPI1 SPEED_HIGH

PA1 LED0 OUTPUT LOW GPIO(90) # Blue LED

define ALLOW_ARM_NO_COMPASS
define HAL_BARO_ALLOW_INIT_NO_BARO

# PWM output pins
PE9  TIM1_CH1 TIM1  PWM(1) GPIO(50) BIDIR
PE11 TIM1_CH2 TIM1  PWM(2) GPIO(51)
PE13 TIM1_CH3 TIM1  PWM(3) GPIO(52) BIDIR
PE14 TIM1_CH4 TIM1  PWM(4) GPIO(53)
PB10 TIM2_CH3 TIM2  PWM(5) GPIO(54) BIDIR
PB11 TIM2_CH4 TIM2  PWM(6) GPIO(55)
PB0  TIM3_CH3 TIM3  PWM(7) GPIO(56) BIDIR
PB1  TIM3_CH4 TIM3  PWM(8) GPIO(57)

# no built-in compass, but probe the i2c bus for all possible
# external compass types22
define ALLOW_ARM_NO_COMPASS
define AP_COMPASS_PROBING_ENABLED 1

# microSD support
PC12 SDMMC1_CK  SDMMC1
PD2  SDMMC1_CMD SDMMC1
PC8  SDMMC1_D0  SDMMC1
PC9  SDMMC1_D1  SDMMC1
PC10 SDMMC1_D2  SDMMC1
PC11 SDMMC1_D3  SDMMC1
define FATFS_HAL_DEVICE SDCD1

# SPI1 - IMU0
PA5 SPI1_SCK SPI1
PA6 SPI1_MISO SPI1
PA7 SPI1_MOSI SPI1
PA4 GYRO1_CS CS

BARO BMP280 I2C:0:0x76

#SPIDEV icm42688 SPI1 DEVID1 ICM42688_CS MODE3  1*MHZ  4*MHZ
SPIDEV bmi160 SPI1 DEVID1 GYRO1_CS MODE3  1*MHZ  4*MHZ
# 2 IMUs
define HAL_USE_EMPTY_STORAGE 1
#define STORAGE_FLASH_PAGE 14
define HAL_STORAGE_SIZE 16384

# enable FAT filesystem support (needs a microSD defined via SDMMC)
define HAL_OS_FATFS_IO 1
#PB0 LED1 OUTPUT LOW