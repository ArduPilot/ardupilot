# hw definition file for processing by chibios_pins.py
# for TBS FCAPv3 H743 (FCAPV3 schematic)
#
# This board shares the TBS_LUCID_H7 (FCAPv1) electrical design but, like the
# OEM variant, has no on-board MAX7456: analog OSD is generated by an on-board
# STM32G431 co-processor that receives MSP DisplayPort frames from the flight
# MCU over UART5 (PB12/PB13). The freed SPI2 pins PB14/PB15 are routed to the
# IMU CLKIN pins (not driven by firmware). RC input moves to UART4 (SBUS),
# leaving USART6 as a spare breakout.
#
# Only the differences from TBS_LUCID_H7 are defined below; everything else is
# inherited via the include.

include ../TBS_LUCID_H7/hwdef.dat

# ---------------- Board ID --------------------
undef APJ_BOARD_ID
APJ_BOARD_ID AP_HW_TBS_LUCID_H7V3

# ---------------- OSD: remove MAX7456 on SPI2 ----------------
# Remove the SPIDEV entry and the SPI2 / MAX7456 chip-select pins. PB12/PB13
# become UART5 to the STM32G431 analog-OSD MCU; PB14/PB15 are wired to
# IMU1/IMU2 CLKIN (left unconfigured, the IMUs use their internal oscillators).
undef osd
undef SPI2
undef PB12 PB13 PB14 PB15

PB12 UART5_RX UART5
PB13 UART5_TX UART5

undef HAL_OSD_TYPE_DEFAULT
define HAL_OSD_TYPE_DEFAULT 5

# ---------------- Motor outputs ----------------
# FCAPV3 numbers the motor pads S1-S10 starting at PA0 (the base board started
# at PB0). Re-declare PWM 1-10 in silk order; PWM 11-13 are unchanged.
undef PB0 PB1 PA0 PA1 PA2 PA3 PD12 PD13 PD14 PD15

PA0  TIM2_CH1 TIM2 PWM(1)  GPIO(50) BIDIR
PA1  TIM2_CH2 TIM2 PWM(2)  GPIO(51)
PA2  TIM5_CH3 TIM5 PWM(3)  GPIO(52) BIDIR
PA3  TIM5_CH4 TIM5 PWM(4)  GPIO(53)
PD12 TIM4_CH1 TIM4 PWM(5)  GPIO(54) BIDIR
PD13 TIM4_CH2 TIM4 PWM(6)  GPIO(55)
PD14 TIM4_CH3 TIM4 PWM(7)  GPIO(56) BIDIR
PD15 TIM4_CH4 TIM4 PWM(8)  GPIO(57)
PB0  TIM3_CH3 TIM3 PWM(9)  GPIO(58) BIDIR
PB1  TIM3_CH4 TIM3 PWM(10) GPIO(59)

# ---------------- Serial order ----------------
# Fill the SERIAL5 slot with the UART5 OSD link. RC input is on UART4 (SBUS),
# so USART6 reverts to a spare. USART1 is not broken out on this board.
undef SERIAL_ORDER
SERIAL_ORDER OTG1 USART1 USART2 USART3 UART4 UART5 USART6 UART7 UART8 OTG2
define DEFAULT_SERIAL5_PROTOCOL SerialProtocol_MSP_DisplayPort

# RC input is on UART4 (was Telem1 on the base board). RC needs DMA, so drop
# the base NODMA on this UART.
undef PB8 PB9
PB9 UART4_TX UART4
PB8 UART4_RX UART4
undef DEFAULT_SERIAL4_PROTOCOL
define DEFAULT_SERIAL4_PROTOCOL SerialProtocol_RCIN

# USART6 was RC input on the base board; here it is a spare breakout, so let it
# fall back to the in-code default (None). Drop its DMA (RC no longer lives
# here) to leave a stream for SPI3 now that UART4/UART5 are DMA-enabled.
undef DEFAULT_SERIAL6_PROTOCOL
undef PC6 PC7
PC6 USART6_TX USART6 NODMA
PC7 USART6_RX USART6 NODMA

# ---------------- Barometer -------------------
# FCAPV3 footprints either DPS368 (DPS310 driver, inherited) or BMP390
# (BMP388 driver) at I2C 0x76 on I2C2; add the BMP388 probe so either variant
# is detected at runtime.
BARO BMP388 I2C:0:0x76

# ---------------- Battery 2 scale -------------
# Vbat2 uses a 200K:10K (21:1) divider per the FCAPV3 schematic; the base hwdef
# inherits an 11:1 scale, so override it here for a correct reading.
undef HAL_BATT2_VOLT_SCALE
define HAL_BATT2_VOLT_SCALE 21.0
