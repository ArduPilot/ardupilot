# Firmware suitable for flashing into a Pixhawk4 to experience Simulation-on-Hardware
include ../Pixhawk4/hwdef.dat
include ../include/SimOnHW.inc
# short board name override (23 chars max)
define CHIBIOS_SHORT_BOARD_NAME "Pixhawk4SimOnHardWare"
# bootloader embedding / bootloader flashing not available
define AP_BOOTLOADER_FLASHING_ENABLED 0
AUTOBUILD_TARGETS Copter
