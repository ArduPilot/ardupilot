# hw definition file for processing by chibios_hwdef.py
# for FMUv3 hardware (ie. for Pixhawk1, Pixhawk2 cube, XUAV2.1 etc)

# the bulk of the FMUv3 configuration lives in fmuv3.inc so that it can
# be shared by boards which are based on FMUv3 but do not share all of
# its hardware (eg. the presence of an IMU heater).
include fmuv3.inc
