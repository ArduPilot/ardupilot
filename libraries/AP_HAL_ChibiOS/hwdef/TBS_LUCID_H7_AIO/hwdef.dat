# hw definition file for processing by chibios_pins.py
# for TBS LUCID H7 AIO (LAIO6S - AIO One 6S, FC + 4in1 ESC)

# MCU class and specific type
MCU STM32H7xx STM32H743xx

# board ID. See Tools/AP_Bootloader/board_types.txt
APJ_BOARD_ID AP_HW_TBS_LUCID_H7_AIO

# crystal frequency, setup to use external oscillator
OSCILLATOR_HZ 8000000

FLASH_SIZE_KB 2048
MCU_CLOCKRATE_MHZ 480

# bootloader takes first sector
FLASH_RESERVE_START_KB 128

# ChibiOS system timer
STM32_ST_USE_TIMER 12
define CH_CFG_ST_RESOLUTION 16

# USB
PA11 OTG_FS_DM OTG1
PA12 OTG_FS_DP OTG1

PA13 JTMS-SWDIO SWD
PA14 JTCK-SWCLK SWD

# SPI1 for IMU (ICM-42688-P)
PA4 GYRO_CS CS
PA5 SPI1_SCK SPI1
PA6 SPI1_MISO SPI1
PA7 SPI1_MOSI SPI1
# IMU INT (PE11) and external CLKIN (PE6, TIM15_CH2) are present in hardware
# but unused: ArduPilot runs the ICM-42688 on its internal clock and FIFO.

# SPI2 for W25Q NOR dataflash
PB12 FLASH_CS CS
PB13 SPI2_SCK SPI2
PB14 SPI2_MISO SPI2
PB15 SPI2_MOSI SPI2

# I2C2 - internal baro, also broken out on an external connector
I2C_ORDER I2C2
PB10 I2C2_SCL I2C2 PULLUP
PB11 I2C2_SDA I2C2 PULLUP

# ADC
PC0 BATT_CURRENT_SENS ADC1 SCALE(1)
PC1 BATT_VOLTAGE_SENS ADC1 SCALE(1)

# battery monitor: 120k/10k divider, 0.25mOhm shunt into INA180A2 (x50 gain)
define HAL_BATT_MONITOR_DEFAULT 4
define HAL_BATT_VOLT_PIN 11
define HAL_BATT_CURR_PIN 10
define HAL_BATT_VOLT_SCALE 13.0
define HAL_BATT_CURR_SCALE 80.0

# status LEDs (active low)
# blue marked ACT, green marked B/E
define AP_NOTIFY_GPIO_LED_2_ENABLED 1
PE3 LED0 OUTPUT LOW GPIO(90) # blue
PE4 LED1 OUTPUT LOW GPIO(91) # green
define HAL_GPIO_A_LED_PIN 91
define HAL_GPIO_B_LED_PIN 90

# order of UARTs (and USB)
SERIAL_ORDER OTG1 USART1 USART2 USART3 UART4 UART5 EMPTY UART7 UART8

# USART1 - 4in1 ESC telemetry (RX only used)
PA9  USART1_TX USART1 NODMA
PA10 USART1_RX USART1 NODMA
define DEFAULT_SERIAL1_PROTOCOL SerialProtocol_ESCTelemetry
define DEFAULT_SERIAL1_BAUD 115

# USART2 - HD VTX (DJI O4) / SmartAudio connector
PA2 USART2_TX USART2
PA3 USART2_RX USART2
define DEFAULT_SERIAL2_PROTOCOL SerialProtocol_None

# USART3 - onboard Crossfire 2.0 receiver
PC10 USART3_TX USART3
PC11 USART3_RX USART3
define DEFAULT_SERIAL3_PROTOCOL SerialProtocol_RCIN

# UART4 - SBUS in (RX only, from DJI O4 connector). Set to RCIN to use.
PA1 UART4_RX UART4 NODMA
define DEFAULT_SERIAL4_PROTOCOL SerialProtocol_None

# UART5 - onboard analog OSD (STM32G431) over MSP DisplayPort
PC12 UART5_TX UART5
PD2  UART5_RX UART5
define DEFAULT_SERIAL5_PROTOCOL SerialProtocol_MSP_DisplayPort

# UART7 - spare (or SmartAudio on TX pad)
PE7 UART7_RX UART7 NODMA
PE8 UART7_TX UART7 NODMA
define DEFAULT_SERIAL7_PROTOCOL SerialProtocol_None

# UART8 - GPS
PE0 UART8_RX UART8
PE1 UART8_TX UART8
define DEFAULT_SERIAL8_PROTOCOL SerialProtocol_GPS

# Motors - internal 4in1 ESC, all on TIM8 (single DShot group)
PC7 TIM8_CH2 TIM8 PWM(1) GPIO(50) BIDIR # M1
PC9 TIM8_CH4 TIM8 PWM(2) GPIO(51) BIDIR # M2
PC6 TIM8_CH1 TIM8 PWM(3) GPIO(52)       # M3
PC8 TIM8_CH3 TIM8 PWM(4) GPIO(53)       # M4

# Motor order implies Betaflight/X for standard ESCs
define HAL_FRAME_TYPE_DEFAULT 12

# serial LED strip
PA0 TIM2_CH1 TIM2 PWM(5) GPIO(54)

# buzzer (active, transistor driven)
PE9 BUZZER OUTPUT LOW GPIO(80)
define HAL_BUZZER_PIN 80

# VTX power switch. Inverted: GPIO LOW = VTX on (Q9 + TPS1H200 load switch).
# Pin starts LOW so the VTX is powered at boot.
PD11 VTX_PWR OUTPUT LOW GPIO(81)
define RELAY2_PIN_DEFAULT 81

DMA_PRIORITY TIM8* SPI1*
DMA_NOSHARE SPI1*

# flash storage for parameters
define HAL_STORAGE_SIZE 32768
# use last 2 pages for flash storage. H743 has 16 pages of 128k each
STORAGE_FLASH_PAGE 14

# logging to onboard W25Q NOR flash
DATAFLASH littlefs:jedec_nor

# spi devices
SPIDEV icm42688  SPI1 DEVID1 GYRO_CS  MODE3  2*MHZ 16*MHZ
SPIDEV dataflash SPI2 DEVID1 FLASH_CS MODE3 32*MHZ 32*MHZ

# one IMU - ICM-42688-P (rotation from the Betaflight target, yaw 225)
IMU Invensensev3 SPI:icm42688 ROTATION_YAW_225
define HAL_DEFAULT_INS_FAST_SAMPLE 1

# onboard baro - DPS368 (uses the DPS310 driver), 0x76 on I2C2
BARO DPS310 I2C:0:0x76

# no built-in compass, but probe the (external) i2c bus for all possible
# external compass types
define ALLOW_ARM_NO_COMPASS
define AP_COMPASS_PROBING_ENABLED 1
define HAL_I2C_INTERNAL_MASK 0
define HAL_COMPASS_AUTO_ROT_DEFAULT 2

# OSD is driven over MSP DisplayPort (onboard analog OSD / HD goggles)
define OSD_ENABLED 1
define HAL_OSD_TYPE_DEFAULT 5

define DEFAULT_NTF_LED_TYPES 455
