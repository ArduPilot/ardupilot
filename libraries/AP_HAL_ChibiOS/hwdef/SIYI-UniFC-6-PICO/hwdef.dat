# hw definition file for processing by chibios_hwdef.py
# for the SIYI-UniFC-6-PICO hardware

# board ID. See Tools/AP_Bootloader/board_types.txt
APJ_BOARD_ID AP_HW_SIYI-UniFC-6-PICO

# MCU class and specific type
MCU STM32H7xx STM32H743xx

# crystal frequency
OSCILLATOR_HZ 16000000

# default to all pins low to avoid ESD issues
DEFAULTGPIO OUTPUT LOW PULLDOWN

# ChibiOS system timer
STM32_ST_USE_TIMER 2

# flash size
FLASH_SIZE_KB 2048

# with 2M flash we can afford to optimize for speed
env OPTIMIZE -O2

# bootloader takes first sector
FLASH_RESERVE_START_KB 128

# order of UARTs (and USB)
SERIAL_ORDER OTG1 USART2 USART6 USART1 UART4 USART3 OTG2

# USB
PA11 OTG_FS_DM OTG1
PA12 OTG_FS_DP OTG1

# pins for SWD debugging
PA13 JTMS-SWDIO SWD
PA14 JTCK-SWCLK SWD

# ethernet
PC1  ETH_MDC            ETH1
PA2  ETH_MDIO           ETH1
PC4  ETH_RMII_RXD0      ETH1
PC5  ETH_RMII_RXD1      ETH1
PB12 ETH_RMII_TXD0      ETH1
PB13 ETH_RMII_TXD1      ETH1
PB11 ETH_RMII_TX_EN     ETH1
PA7  ETH_RMII_CRS_DV    ETH1
PA1  ETH_RMII_REF_CLK   ETH1

define BOARD_PHY_ID  MII_LAN8742A_ID
define BOARD_PHY_RMII

# UART

# USART2 Telem1
PD5  USART2_TX  USART2
PD6  USART2_RX  USART2
PD3  USART2_CTS USART2
PD4  USART2_RTS USART2

# USART6 Telem2
PC6  USART6_TX  USART6
PC7  USART6_RX  USART6
PG12 USART6_RTS USART6
PG13 USART6_CTS USART6

# USART3 Telem3
PD8  USART3_TX USART3
PD9  USART3_RX USART3

# UART4 GPS2/Telem4
PI9  UART4_RX UART4
PB9  UART4_TX UART4

# USART1 GPS
PB14 USART1_TX USART1
PB15 USART1_RX USART1

# SPI
# SPI1  BMI088
PG11 SPI1_SCK  SPI1
PG9  SPI1_MISO SPI1
PD7  SPI1_MOSI SPI1

# SPI4  ICM45686
PE2  SPI4_SCK  SPI4
PE5  SPI4_MISO SPI4
PE6  SPI4_MOSI SPI4

# SPI5  FRAM
PF7  SPI5_SCK  SPI5
PF8  SPI5_MISO SPI5
PF9  SPI5_MOSI SPI5

# CS pins
PE3   ICM45686_1_CS CS
PG4   BMI088_A_CS   CS
PA10  BMI088_G_CS   CS
PF10  FRAM_CS       CS

# enable pins
PE10  VDD_3V3_SPI1_EN         OUTPUT HIGH  # BMI088   SPI1
PI4   VDD_3V3_ICP20100_1_EN   OUTPUT HIGH  # ICP20100 1
PI11  VDD_3V3_ICP20100_2_EN   OUTPUT HIGH  # ICP20100 2
PG0   VDD_3V3_SPI4_EN 	      OUTPUT HIGH  # ICM45686 SPI4
PB1   VDD_3V3_SD_CARD_EN      OUTPUT HIGH  # SDCARD
PG8   VDD_3V3_IST8310_EN      OUTPUT HIGH  # IST8310

# drdy pins
PC13   ICM45686_DRDY    INPUT  # ICM45686
PG5    BMI088_A_DRDY    INPUT  # DRDY1
PG6    BMI088_G_DRDY    INPUT  # DRDY3

# SPI_DEVICES
SPIDEV bmi088_g    SPI1  DEVID1  BMI088_G_CS    MODE3   10*MHZ  10*MHZ
SPIDEV bmi088_a    SPI1  DEVID2  BMI088_A_CS    MODE3   10*MHZ  10*MHZ
SPIDEV icm45686_1  SPI4  DEVID1  ICM45686_1_CS  MODE3   2*MHZ   8*MHZ
SPIDEV ramtron     SPI5  DEVID1  FRAM_CS        MODE3   8*MHZ   8*MHZ

# I2C
# I2C1
PB8 I2C1_SCL I2C1
PB7 I2C1_SDA I2C1

# I2C2
PF1 I2C2_SCL I2C2
PF0 I2C2_SDA I2C2

# I2C3
PH7 I2C3_SCL I2C3
PH8 I2C3_SDA I2C3

# I2C4
PF15 I2C4_SDA I2C4
PF14 I2C4_SCL I2C4

# order of I2C buses
I2C_ORDER I2C3 I2C1 I2C4 I2C2
define HAL_I2C_INTERNAL_MASK 1

# PWM * 14
# PWM output pins
PE9  TIM1_CH1  TIM1  PWM(1)   GPIO(50) BIDIR
PE11 TIM1_CH2  TIM1  PWM(2)   GPIO(51)
PE13 TIM1_CH3  TIM1  PWM(3)   GPIO(52) BIDIR
PE14 TIM1_CH4  TIM1  PWM(4)   GPIO(53)
PD12 TIM4_CH1  TIM4  PWM(5)   GPIO(54)
PD13 TIM4_CH2  TIM4  PWM(6)   GPIO(55)
PD14 TIM4_CH3  TIM4  PWM(7)   GPIO(56)
PD15 TIM4_CH4  TIM4  PWM(8)   GPIO(57)
PH10 TIM5_CH1  TIM5  PWM(9)   GPIO(58)
PH11 TIM5_CH2  TIM5  PWM(10)  GPIO(59)
PH12 TIM5_CH3  TIM5  PWM(11)  GPIO(60)
PI0  TIM5_CH4  TIM5  PWM(12)  GPIO(61)

# timer 12 doesn't have a TIMn_UP DMA option
PH6  TIM12_CH1 TIM12 PWM(13)  GPIO(62) NODMA
PH9  TIM12_CH2 TIM12 PWM(14)  GPIO(63) NODMA

# RC
PI5 TIM8_CH1 TIM8 RCININT PULLDOWN LOW

# BUZZER
PF6 TIM16_CH1 TIM16 GPIO(77) ALARM

# IMU HEATER
PG7 HEATER_EN OUTPUT LOW GPIO(80)
define HAL_HEATER_GPIO_PIN 80

# Setup the IMU heater
define HAL_HAVE_IMU_HEATER 1
define HAL_IMU_TEMP_DEFAULT 45
define HAL_IMUHEAT_P_DEFAULT 50
define HAL_IMUHEAT_I_DEFAULT 0.07

# safety
# allow to have a dedicated safety switch pin
define HAL_HAVE_SAFETY_SWITCH 1
PD10 LED_SAFETY OUTPUT
PD11 SAFETY_IN INPUT PULLDOWN

# analog in
PF12  BATT_VOLTAGE_SENS ADC1 SCALE(1) ANALOG(4) # BATTERTY VLOTAGE
PF11  BATT_CURRENT_SENS ADC1 SCALE(1) ANALOG(5) # BATTERY CURRENT
# ADC
PA5  SCALED1_V3V3           ADC1 SCALE(2) # SENSOR VOLTAGE SAMPLE
PC0  SCALED2_V3V3           ADC2 SCALE(2) # SENSOR VOLTAGE SAMPLE
PF13 SCALED3_V3V3           ADC2 SCALE(2) # SENSOR VOLTAGE SAMPLE
PA6  SCALED4_V3V3           ADC1 SCALE(2) # SENSOR VOLTAGE SAMPLE
PC2  VDD_5V_SENS            ADC1 SCALE(2) # 5V INPUT
PA4  FMU_SERVORAIL_VCC_SENS ADC1 SCALE(3) # SERVO SAMPLE

# setup scaling defaults for supplied power brick
define HAL_BATT_MONITOR_DEFAULT 4
define HAL_BATT_VOLT_PIN 4
define HAL_BATT_CURR_PIN 5
define HAL_BATT_VOLT_SCALE 18.182
define HAL_BATT_CURR_SCALE 36.364

# CAN bus
PD0  CAN1_RX CAN1
PD1  CAN1_TX CAN1
PG15 GPIO_CAN1_SILENT OUTPUT PUSHPULL SPEED_LOW LOW GPIO(70)

PB5  CAN2_RX CAN2
PB6  CAN2_TX CAN2
PA15 GPIO_CAN2_SILENT OUTPUT PUSHPULL SPEED_LOW LOW GPIO(71)

# Pin for PWM Voltage Selection, 0 means 3.3v, 1 means 5v, 3.3v default
PE12 PWM_VOLT_SEL OUTPUT LOW GPIO(81)
define HAL_GPIO_PWM_VOLT_PIN 81
define HAL_GPIO_PWM_VOLT_3v3 0

# SDMMC1
PC8  SDMMC1_D0  SDMMC1
PC9  SDMMC1_D1  SDMMC1
PC10 SDMMC1_D2  SDMMC1
PC11 SDMMC1_D3  SDMMC1
PC12 SDMMC1_CK  SDMMC1
PD2  SDMMC1_CMD SDMMC1

# LEDs
PH2 LED_R1 OUTPUT OPENDRAIN HIGH GPIO(41)
PH3 LED_G1 OUTPUT OPENDRAIN LOW  GPIO(42)
PH4 LED_B1 OUTPUT OPENDRAIN HIGH GPIO(43)

# setup for "AP_BoardLED" RGB LEDs
define AP_NOTIFY_GPIO_LED_RGB_RED_PIN 41
define AP_NOTIFY_GPIO_LED_RGB_GREEN_PIN 42
define AP_NOTIFY_GPIO_LED_RGB_BLUE_PIN 43

# use pixracer style 3-LED indicators
define AP_NOTIFY_GPIO_LED_RGB_ENABLED 1

# IMU
IMU Invensensev3 SPI:icm45686_1 ROTATION_PITCH_180
IMU BMI088 SPI:bmi088_a SPI:bmi088_g ROTATION_YAW_90

define HAL_DEFAULT_INS_FAST_SAMPLE 3
define ICM45686_CLKIN 1
define HAL_INS_HIGHRES_SAMPLE 3

# BARO
BARO ICP201XX I2C:0:0x63
BARO ICP201XX I2C:3:0x64

# COMPASS
define AP_COMPASS_PROBING_ENABLED 1
define AP_COMPASS_INTERNAL_BUS_PROBING_ENABLED 0
COMPASS IST8310 I2C:0:0x0E     false  ROTATION_YAW_270
define AP_COMPASS_IST8310_DEFAULT_ROTATION ROTATION_NONE

# enable RAMTROM parameter storage
define HAL_STORAGE_SIZE 32768
define HAL_WITH_RAMTRON 1

# enable FAT filesystem support (needs a microSD defined via SDMMC)
define HAL_OS_FATFS_IO 1

# DMA
DMA_PRIORITY  SPI* TIM* UART* USART* SDMMC* ADC*
DMA_NOSHARE  SPI1*

# enable DFU reboot for installing bootloader
# note that if firmware is build with --secure-bl then DFU is
# disabled
ENABLE_DFU_BOOT 1

# build ABIN for flash-from-bootloader support:
env BUILD_ABIN True
