{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "PLAV_SITL",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/sitl/bin/arduplane",
            "args": [
                "-S",                     // Silent mode (minimal output)
                "--model", "+",           // Specify model type; "+" is placeholder
                "--speedup", "1",         // Simulation speed multiplier
                "--slave", "0",           // SITL slave mode
                "--sim-address=127.0.0.1",// IP used to connect to SITL
                "-IO"                     // Input/output options
            ],
            "cwd": "${workspaceFolder}/ArduPlane",
            "MIMode": "gdb",
            "preLaunchTask": "Start PLAV SITL",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ],
            "externalConsole": false,
            "stopAtEntry": false
        }
    ]
}
