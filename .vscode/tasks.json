{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start PLAV SITL",
            "type": "shell",
            "command": "../Tools/autotest/sim_vehicle.py",
            "args": [
                "-f", "JSON:127.0.0.1", // Connect via JSON protocol
                "-L", "BRGRBalloon",    // Vehicle/Location choice
                "--console",            // Show console output
                "--map",                // Show map GUI
                "--osd",                // Show On-Screen Display
                "-D"                    // Enable debug output
            ],
            "options": {
                "cwd": "${workspaceFolder}/ArduPlane"
            },
            "isBackground": true,
            "problemMatcher": {
                "pattern": [
                    {
                        "regexp": ".",
                        "file": 1,
                        "location": 2,
                        "message": 3
                    }
                ],
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".*",
                    "endsPattern": ".*"
                }
            }
        }
    ]
}
